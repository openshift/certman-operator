FROM scratch

LABEL com.redhat.component="openshift-certman-operator" \
      io.k8s.description="certman-operator Operator for OpenShift Dedicated" \
      description="certman-operator Operator for OpenShift Dedicated" \
      distribution-scope="public" \
      name="openshift/certman-operator" \
      url="https://github.com/openshift/certman-operator" \
      vendor="Red Hat, Inc." \
      release="v0.0.0" \
      version="v0.0.0"

COPY deploy_pko/ /package/
USER 1001

